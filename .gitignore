# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Terraform-module
# ─────────────────────────────────────────────────────────────────────────────

# ─── Terraform State ─────────────────────────────────────────────────────────
# NEVER commit state files — they may contain secrets and cause team conflicts.
# Use a remote backend (S3 + DynamoDB) configured in backend.tf.
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directory (downloaded providers + modules)
**/.terraform/
**/.terraform.lock.hcl

# Terraform plan output (binary) — safe to commit the text output (plan.txt)
*.tfplan

# Crash and debug logs
crash.log
crash.*.log

# Override files (local-only, not for version control)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# ─── Database Backups ────────────────────────────────────────────────────────
# Backup dumps are large binary files — store in S3 or similar, not git.
backups/
*.sql.gz
*.dump

# ─── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
